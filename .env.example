# Discord bot token — obtain from Discord Developer Portal > Bot > Token
DISCORD_TOKEN=

# PostgreSQL connection URL
DATABASE_URL=postgres://secretary:secretpassword@localhost:5432/secretary

# PostgreSQL pool size (optional, defaults shown)
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# Gemini API key — obtain from Google AI Studio
GEMINI_API_KEY=

# Extraction interval in minutes per guild (optional, default: 60)
# EXTRACTION_INTERVAL_MINS=60

# MCP server port (optional, default: 3100)
# MCP_PORT=3100

# MCP authentication token — shared secret for agent access
MCP_AUTH_TOKEN=

# Cloudflare Tunnel token (for production deployment)
# CF_TUNNEL_TOKEN=

# PostgreSQL password (used by Docker Compose for the postgres service)
PG_PASSWORD=secretpassword

# Log level: error, warn, info, debug (optional, default: info)
# LOG_LEVEL=info
