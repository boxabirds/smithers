{
  "name": "discord-secretary",
  "version": "0.1.0",
  "description": "Discord bot that monitors conversations, builds a knowledge base, and exposes insights via MCP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp/server.js",
    "dev": "tsx src/index.ts",
    "migrate": "node dist/db/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "discord",
    "mcp",
    "knowledge-base"
  ],
  "license": "ISC",
  "dependencies": {
    "@arcjet/redact": "^1.3.0",
    "@google/generative-ai": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "discord.js": "^14.18.0",
    "pg": "^8.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
